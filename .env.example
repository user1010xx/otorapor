# ============================================================
# Railway Variables (Settings → Variables)
# Aşağıdaki KEY=VALUE çiftlerini Railway'e ekleyin.
# Gerçek secret değerleri ASLA git'e commit etmeyin.
# ============================================================

# --- ZORUNLU ---

# BotFather'dan alınan token
TELEGRAM_BOT_TOKEN=

# Botun rapor atacağı Telegram grup chat id (genelde -100 ile başlar)
# Öğrenme: botu gruba ekle → gruba mesaj yaz →
# https://api.telegram.org/bot<TOKEN>/getUpdates → chat.id
TELEGRAM_CHAT_ID=

# Toniva Admin → API Erişimi → Anahtarlar
# Gerekli scope: reports:read
TONIVA_API_KEY=

# --- ÖNERİLEN ---

# Saat dilimi (otomatik rapor saatleri için)
TZ=Europe/Istanbul

# --- OPSİYONEL ---

# Varsayılan: https://crm.toniva.net/api/public/v1
TONIVA_BASE_URL=https://crm.toniva.net/api/public/v1
